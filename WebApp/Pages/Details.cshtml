@page "{id:int}"
@model DetailsModel
@{
    ViewData["Title"] = "Details";
}

<h1
    class ="text-4xl font-extrabold text-white drop-shadow-lg animate-pulse">
    Pokémon Details!
</h1>

@if (Model.Pokemon?.Abilities?.Any() == true)
{
    <div class="mt-6 bg-black/30 rounded-xl p-4 shadow-lg">
        <h3 class="text-xl font-bold text-white mb-3">
            Abilities
        </h3>

        <ul class="space-y-2">
            @foreach (var ability in Model.Pokemon.Abilities.OrderBy(a => a.Slot))
            {
                <li>
                    <form method="post"
                          asp-page-handler="FetchAbilities"
                          class="bg-white/10 rounded-lg hover:bg-white/20 transition">

                        <input type="hidden"
                               name="abilityName"
                               value="@ability.AbilityAbility.Name" />

                        <button type="submit"
                                class="w-full flex items-center justify-between px-4 py-2 cursor-pointer">

                            <div class="flex items-center gap-3">
                                <span class="capitalize font-semibold text-white">
                                    @ability.AbilityAbility.Name.Replace("-", " ")
                                </span>

                                <span class="text-xs text-white/60">
                                    Slot @ability.Slot
                                </span>
                            </div>

                            @if (ability.IsHidden)
                            {
                                <span class="text-xs bg-purple-600 text-white px-2 py-1 rounded-full">
                                    Hidden
                                </span>
                            }
                        </button>
                    </form>
                </li>
            }
        </ul>
    </div>
}

